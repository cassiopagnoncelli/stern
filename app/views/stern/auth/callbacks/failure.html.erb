<div class="max-w-xl mx-auto p-12 text-center">
  <div class="text-6xl mb-4 text-gray-900 dark:text-gray-100">⚠</div>
  <h1 class="text-2xl font-bold mb-2 text-gray-900 dark:text-gray-100">Sign-in failed</h1>
  <p class="text-gray-600 dark:text-gray-400 mb-2">
    We couldn't complete the sign-in with the identity provider.
  </p>
  <% if @auth_failure_reason.present? %>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-6"><code class="px-1 bg-gray-100 dark:bg-gray-800 rounded"><%= @auth_failure_reason %></code></p>
  <% else %>
    <p class="mb-6"></p>
  <% end %>
  <div class="flex justify-center gap-3">
    <a href="/stern" class="px-4 py-2 bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-gray-100 rounded hover:bg-gray-300 dark:hover:bg-gray-600">Home</a>
    <a href="/stern/auth/idp/start" class="px-4 py-2 bg-blue-600 dark:bg-blue-500 text-white rounded hover:bg-blue-700 dark:hover:bg-blue-400">Try again</a>
  </div>
</div>
