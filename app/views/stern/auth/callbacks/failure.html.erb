<div class="max-w-xl mx-auto p-12 text-center">
  <div class="text-6xl mb-4">⚠</div>
  <h1 class="text-2xl font-bold mb-2">Sign-in failed</h1>
  <p class="text-gray-600 mb-2">
    We couldn't complete the sign-in with the identity provider.
  </p>
  <% if @auth_failure_reason.present? %>
    <p class="text-sm text-gray-500 mb-6"><code class="px-1 bg-gray-100 rounded"><%= @auth_failure_reason %></code></p>
  <% else %>
    <p class="mb-6"></p>
  <% end %>
  <div class="flex justify-center gap-3">
    <a href="/stern" class="px-4 py-2 bg-gray-200 text-gray-800 rounded hover:bg-gray-300">Home</a>
    <a href="/stern/auth/idp/start" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">Try again</a>
  </div>
</div>
