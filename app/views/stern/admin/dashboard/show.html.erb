<div class="max-w-3xl mx-auto p-8">
  <h1 class="text-3xl font-bold mb-4">Stern Admin</h1>
  <div class="bg-white shadow rounded p-6 space-y-2">
    <p><span class="font-semibold">Signed in as:</span> <%= current_passport.email %></p>
    <p><span class="font-semibold">User UUID:</span> <%= current_passport.user_uuid %></p>
    <p>
      <span class="font-semibold">Role:</span>
      <% if current_passport.platform_admin_root? %>
        <span class="inline-block px-2 py-0.5 text-xs rounded bg-red-100 text-red-800">platform_admin_root</span>
      <% end %>
      <% if current_passport.platform_admin? %>
        <span class="inline-block px-2 py-0.5 text-xs rounded bg-blue-100 text-blue-800">platform_admin</span>
      <% end %>
    </p>
  </div>
</div>
