<div class="max-w-3xl mx-auto p-8 space-y-6">
  <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">Stern Admin</h1>

  <div class="bg-white dark:bg-gray-800 shadow rounded p-6 space-y-2 text-gray-900 dark:text-gray-100">
    <p class="flex flex-wrap items-center gap-2">
      <span><%= current_passport.email %></span>
      <button
        type="button"
        data-copy-uuid="<%= current_passport.user_uuid %>"
        title="Copy UUID"
        aria-label="Copy UUID <%= current_passport.user_uuid %>"
        class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-mono rounded-full bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 hover:bg-gray-200 dark:hover:bg-gray-600 cursor-pointer border border-gray-200 dark:border-gray-600">
        <span><%= current_passport.user_uuid %></span>
        <svg data-copy-icon class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg">
          <rect x="9" y="9" width="11" height="11" rx="2" stroke-width="2"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15V6a2 2 0 0 1 2-2h9"/>
        </svg>
        <svg data-copy-check class="h-3 w-3 hidden text-green-600 dark:text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 12l5 5L20 7"/>
        </svg>
      </button>
      <% if current_passport.platform_admin_root? %>
        <span class="inline-block px-2 py-0.5 text-xs rounded bg-red-100 dark:bg-red-900/40 text-red-800 dark:text-red-200">platform_admin_root</span>
      <% end %>
      <% if current_passport.platform_admin? %>
        <span class="inline-block px-2 py-0.5 text-xs rounded bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-200">platform_admin</span>
      <% end %>
    </p>
    <p class="flex items-center gap-2">
      <svg class="h-4 w-4 text-gray-600 dark:text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <ellipse cx="12" cy="5" rx="8" ry="3" stroke-width="2"/>
        <path stroke-width="2" d="M4 5v6c0 1.66 3.58 3 8 3s8-1.34 8-3V5"/>
        <path stroke-width="2" d="M4 11v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6"/>
      </svg>
      <span><%= ::Stern::ApplicationRecord.connection_db_config.database %></span>
    </p>
  </div>
</div>

<script>
  (function () {
    document.addEventListener("click", function (event) {
      var btn = event.target.closest("[data-copy-uuid]");
      if (!btn) return;
      var uuid = btn.getAttribute("data-copy-uuid");
      var done = function () {
        var original = btn.getAttribute("title");
        var copyIcon = btn.querySelector("[data-copy-icon]");
        var checkIcon = btn.querySelector("[data-copy-check]");
        btn.setAttribute("title", "Copied!");
        if (copyIcon) copyIcon.classList.add("hidden");
        if (checkIcon) checkIcon.classList.remove("hidden");
        setTimeout(function () {
          btn.setAttribute("title", original);
          if (copyIcon) copyIcon.classList.remove("hidden");
          if (checkIcon) checkIcon.classList.add("hidden");
        }, 1000);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(uuid).then(done).catch(function () {});
      } else {
        var ta = document.createElement("textarea");
        ta.value = uuid;
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand("copy"); done(); } catch (e) {}
        document.body.removeChild(ta);
      }
    });
  })();
</script>
