<%
  status_badge_classes = lambda do |status|
    case status
    when "success" then "bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-200"
    when "failed"  then "bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-200"
    when "pending" then "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-200"
    else "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200"
    end
  end

  format_params = lambda do |params|
    return "" if params.blank?
    params.map { |k, v| "#{k}=#{v.is_a?(String) ? v : v.inspect}" }.join(" ")
  end
%>

<table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
  <thead class="bg-gray-50 dark:bg-gray-700">
    <tr>
      <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
        Attempted at
        <span class="ml-1 normal-case font-normal text-gray-400 dark:text-gray-500"><%= Time.zone.now.strftime("%Z") %></span>
      </th>
      <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Operation</th>
      <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Operation ID</th>
      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Idempotency key</th>
      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Params</th>
      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Error</th>
    </tr>
  </thead>
  <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
    <% attempts.each do |attempt| %>
      <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
        <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-900 dark:text-gray-100">
          <%= attempt.attempted_at.in_time_zone.strftime("%b %d, %Y at %I:%M:%S %p") %>
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-center">
          <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= status_badge_classes.call(attempt.status) %>">
            <%= attempt.status.titleize %>
          </span>
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-left text-sm text-gray-900 dark:text-gray-100">
          <%= attempt.name %>
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-900 dark:text-gray-100 font-mono">
          <%= attempt.operation_id || "—" %>
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-left text-sm text-gray-700 dark:text-gray-300 font-mono">
          <%= attempt.idem_key.presence || "—" %>
        </td>
        <td class="px-6 py-4 text-left text-sm text-gray-700 dark:text-gray-300 font-mono break-all">
          <%= format_params.call(attempt.params) %>
        </td>
        <td class="px-6 py-4 text-left text-sm">
          <% if attempt.failed? %>
            <div class="text-red-600 dark:text-red-400 font-medium">
              <%= attempt.error_class %>
            </div>
            <div class="text-xs text-gray-600 dark:text-gray-400 break-words" title="<%= attempt.error_backtrace %>">
              <%= attempt.error_message %>
            </div>
          <% else %>
            <span class="text-gray-400 dark:text-gray-500">—</span>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
