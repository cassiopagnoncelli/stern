<% field_classes = "w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 px-2 py-2 text-sm focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 dark:focus:border-indigo-400 dark:focus:ring-indigo-400" %>

<div class="shrink-0">
  <%= form.label :status, "Status", class: "sr-only" %>
  <%= form.select :status,
      options_for_select([ [ "Any status", "" ] ] + statuses.map { |s| [ s.titleize, s ] }, status),
      {},
      class: "select-menu",
      onchange: "this.form.submit()" %>
</div>

<div class="shrink-0">
  <%= form.label :name, "Operation", class: "sr-only" %>
  <%= form.select :name,
      options_for_select([ [ "Any operation", "" ] ] + operation_names.map { |n| [ n, n ] }, name),
      {},
      class: "select-menu",
      onchange: "this.form.submit()" %>
</div>

<div class="min-w-0 flex-1 sm:max-w-56">
  <%= form.label :idem_key, "Idempotency key", class: "sr-only" %>
  <%= form.text_field :idem_key,
      value: idem_key,
      placeholder: "Idempotency key",
      class: field_classes %>
</div>

<div class="shrink-0">
  <%= render "stern/admin/ledger/date_range_picker",
      picker_id: "attempts-date-range",
      start_date: start_date,
      end_date: end_date %>
</div>

<button type="submit"
        title="Apply filters"
        aria-label="Apply filters"
        class="shrink-0 inline-flex items-center justify-center h-9 w-9 rounded-md shadow-sm text-white bg-indigo-600 dark:bg-indigo-500 hover:bg-indigo-700 dark:hover:bg-indigo-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 dark:focus:ring-indigo-400">
  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7M21 12H3"/>
  </svg>
</button>
