<% field_classes = "w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 dark:focus:border-indigo-400 dark:focus:ring-indigo-400" %>

<div class="w-full sm:w-auto">
  <%= form.label :status, "Status", class: "sr-only" %>
  <%= form.select :status,
      options_for_select([ [ "Any status", "" ] ] + statuses.map { |s| [ s.titleize, s ] }, status),
      {},
      class: "select-menu",
      onchange: "this.form.submit()" %>
</div>

<div class="w-full sm:w-auto">
  <%= form.label :name, "Operation", class: "sr-only" %>
  <%= form.select :name,
      options_for_select([ [ "Any operation", "" ] ] + operation_names.map { |n| [ n, n ] }, name),
      {},
      class: "select-menu",
      onchange: "this.form.submit()" %>
</div>

<div class="w-full sm:w-48">
  <%= form.label :idem_key, "Idempotency key", class: "sr-only" %>
  <%= form.text_field :idem_key,
      value: idem_key,
      placeholder: "Idempotency key",
      class: field_classes %>
</div>

<%= render "stern/admin/ledger/date_range_picker",
    picker_id: "attempts-date-range",
    start_date: start_date,
    end_date: end_date %>

<button type="submit" class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 dark:bg-indigo-500 hover:bg-indigo-700 dark:hover:bg-indigo-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 dark:focus:ring-indigo-400">
  Apply
</button>
