<% field_classes = "w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 dark:focus:border-indigo-400 dark:focus:ring-indigo-400" %>

<div class="w-full sm:w-auto">
  <%= form.label :decimal_places, "Decimal places", class: "sr-only" %>
  <%= form.select :decimal_places,
      options_for_select((0..10).map { |value| [ value.to_s, value ] }, decimal_places),
      {},
      class: field_classes,
      onchange: "this.form.submit()" %>
</div>

<div class="w-full sm:w-auto">
  <%= form.label :currency, "Currency", class: "sr-only" %>
  <%= form.select :currency,
      options_for_select(currencies.map { |name| [ name, name ] }, currency),
      {},
      class: field_classes,
      onchange: "this.form.submit()" %>
</div>

<div class="w-full sm:w-28">
  <%= form.label :gid, "GID", class: "sr-only" %>
  <%= form.number_field :gid,
      value: gid,
      placeholder: "GID",
      class: field_classes %>
</div>

<div class="w-full sm:w-auto">
  <%= form.label :book_id, "Book ID", class: "sr-only" %>
  <%= form.select :book_id,
      options_for_select([ [ "All books", "" ] ] + books.map { |name, code| [ "#{name} (#{code})", code ] }, book_id&.to_i),
      {},
      class: field_classes,
      onchange: "this.form.submit()" %>
</div>

<div class="w-full sm:w-auto">
  <%= form.label :start_date, "Start date", class: "sr-only" %>
  <%= form.datetime_local_field :start_date,
      value: start_date,
      class: field_classes %>
</div>

<div class="w-full sm:w-auto">
  <%= form.label :end_date, "End date", class: "sr-only" %>
  <%= form.datetime_local_field :end_date,
      value: end_date,
      class: field_classes %>
</div>

<button type="submit" class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 dark:bg-indigo-500 hover:bg-indigo-700 dark:hover:bg-indigo-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 dark:focus:ring-indigo-400">
  Apply
</button>
