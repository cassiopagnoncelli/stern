<% content_for :title, "Ledger - Balance Sheet" %>

<div class="max-w-7xl mx-auto p-6">
  <%= render "stern/admin/shared/paginated_table",
      title: "Balance Sheet",
      subtitle: "Review account balances across selected books and time range.",
      has_records: @balance_sheet.any?,
      pagination: false,
      filters_url: admin_ledger_balance_sheet_path,
      filters_form_id: "ledger-balance-sheet-filters-form",
      filters_form_class: "flex w-full flex-wrap items-end gap-2 justify-end",
      filters_partial: "stern/admin/ledger/balance_sheet_filters",
      filters_locals: {
        decimal_places: @decimal_places,
        start_date: @start_date_filter_value,
        end_date: @end_date_filter_value,
        books: @books,
        book_groups: @book_groups,
        selected_book_ids: @book_ids,
        currency: @currency,
        currency_groups: @currency_groups
      },
      body_content: render("stern/admin/ledger/balance_sheet_table", balance_sheet: @balance_sheet, decimal_places: @decimal_places),
      empty_state_text: "No data found for the selected books and date range." %>
</div>
