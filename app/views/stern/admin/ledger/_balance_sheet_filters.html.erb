<% field_classes = "w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 dark:focus:border-indigo-400 dark:focus:ring-indigo-400" %>

<%= render "stern/admin/ledger/balance_sheet_preset_picker",
    picker_id: "balance-sheet-presets",
    presets: Stern::Admin::BalanceSheetPreset.all,
    books: books %>

<div class="w-full sm:w-auto">
  <%= form.label :currency, "Currency", class: "sr-only" %>
  <%= form.select :currency,
      grouped_options_for_select(currency_groups.transform_values { |names| names.map { |n| [ currency_display_label(n), n ] } }, currency),
      {},
      class: "select-menu",
      onchange: "this.form.submit()" %>
</div>

<%= render "stern/admin/ledger/date_range_picker",
    picker_id: "balance-sheet-date-range",
    start_date: start_date,
    end_date: end_date %>

<%= render "stern/admin/ledger/books_picker",
    picker_id: "balance-sheet-books",
    mode: :multi,
    compact: true,
    books: books,
    book_groups: book_groups,
    selected_book_ids: selected_book_ids %>

<a role="button"
   tabindex="0"
   title="Apply"
   aria-label="Apply"
   onclick="this.closest('form').requestSubmit();"
   onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();this.closest('form').requestSubmit();}"
   class="inline-flex items-center justify-center p-1 cursor-pointer text-gray-500 hover:text-indigo-600 dark:text-gray-400 dark:hover:text-indigo-400 focus:outline-none focus:text-indigo-600 dark:focus:text-indigo-400">
  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
  </svg>
</a>
